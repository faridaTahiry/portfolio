# Copy to .env and fill in. Do not commit .env.
# Google: Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Add authorized JavaScript origins: http://localhost:5173 and your Netlify URL.
VITE_GOOGLE_CLIENT_ID=

# Python backend URL (run backend from repo root: cd backend && uvicorn main:app --reload --port 8000)
# Production: your deployed backend (e.g. https://calendar-coach-api.onrender.com)
VITE_CALENDAR_API_URL=http://localhost:8000
